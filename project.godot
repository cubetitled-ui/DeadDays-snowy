; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Deadays"
run/main_scene="uid://cf6o73wshtqv7"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/show_image=false
config/icon="uid://bamje4ysbbqrg"

[autoload]

Settings="*res://Scripts/settings.gd"
DebugMenu="*uid://cggqb75a8w8r"
GameStats="*res://Scripts/game_stats.gd"
ModLoader="*res://addons/mod_loader/mod_loader.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/debug_menu/plugin.cfg", "res://addons/snowy_tools/plugin.cfg")

[global_group]

player=""
navigation_mesh_source_group=""
pickup=""
spawner=""
zombies=""
wave_manager=""
instanced=""
flying=""
spawnpoint=""

[gui]

