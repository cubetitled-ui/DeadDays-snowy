[layer_names]

3d_physics/layer_1="Enviroment"
3d_physics/layer_2="Characters"
3d_physics/layer_3="Hitboxes"
3d_physics/layer_5="Pickups"
3d_physics/layer_6="Spawners"
3d_physics/layer_7="gibs"
3d_physics/layer_8="Zombies"
3d_physics/layer_9="ZombieEnters"
